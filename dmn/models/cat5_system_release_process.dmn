<?xml version="1.0" encoding="UTF-8"?>
<definitions
  xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
  xmlns:feel="https://www.omg.org/spec/DMN/20191111/FEEL/"
  id="cat5_system_release_process"
  name="cat5_system_release_process"
  namespace="http://example.com/cat5">

  <!-- ============================================================
       INPUTS
       ============================================================ -->
  <inputData id="input_program" name="program">
    <variable id="var_program" name="program" typeRef="string"/>
  </inputData>

  <inputData id="input_airgap" name="airgap">
    <variable id="var_airgap" name="airgap" typeRef="string"/>
  </inputData>

  <inputData id="input_tsr_verdict" name="tsr_verdict">
    <variable id="var_tsr_verdict" name="tsr_verdict" typeRef="string"/>
  </inputData>

  <inputData id="input_dvr_status" name="dvr_status">
    <variable id="var_dvr_status" name="dvr_status" typeRef="string"/>
  </inputData>

  <inputData id="input_open_defects" name="open_defects_summary">
    <variable id="var_open_defects" name="open_defects_summary" typeRef="context"/>
  </inputData>

  <inputData id="input_safety" name="safety_coverage">
    <variable id="var_safety" name="safety_coverage" typeRef="string"/>
  </inputData>

  <inputData id="input_requirements" name="requirements_coverage">
    <variable id="var_requirements" name="requirements_coverage" typeRef="string"/>
  </inputData>

  <!-- ============================================================
       DECISION 1: Context Alignment
       ============================================================ -->
  <decision id="context_alignment" name="context_alignment">
    <variable name="context_alignment" typeRef="string"/>
    <decisionTable hitPolicy="UNIQUE">
      <input id="program_col" label="program">
        <inputExpression><text>program</text></inputExpression>
      </input>

      <input id="airgap_col" label="airgap">
        <inputExpression><text>airgap</text></inputExpression>
      </input>

      <output id="alignment_out" name="alignment" typeRef="string"/>

      <rule>
        <inputEntry><text>"C121"</text></inputEntry>
        <inputEntry><text>"C121_BIN"</text></inputEntry>
        <outputEntry><text>"OK"</text></outputEntry>
      </rule>

      <rule>
        <inputEntry><text>"P768"</text></inputEntry>
        <inputEntry><text>"P768_BIN"</text></inputEntry>
        <outputEntry><text>"OK"</text></outputEntry>
      </rule>

      <rule>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"MISMATCH"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <!-- ============================================================
       DECISION 2: Defect Posture
       ============================================================ -->
  <decision id="defect_posture" name="defect_posture">
    <variable name="defect_posture" typeRef="string"/>
    <decisionTable hitPolicy="FIRST">
      <input label="critical">
        <inputExpression><text>open_defects_summary.critical</text></inputExpression>
      </input>
      <input label="major">
        <inputExpression><text>open_defects_summary.major</text></inputExpression>
      </input>
      <input label="minor">
        <inputExpression><text>open_defects_summary.minor</text></inputExpression>
      </input>

      <output name="defect_result" typeRef="string"/>

      <rule>
        <inputEntry><text>&gt; 0</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"FAIL_CRITICAL"</text></outputEntry>
      </rule>

      <rule>
        <inputEntry><text>0</text></inputEntry>
        <inputEntry><text>&gt; 0</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"FAIL_MAJOR"</text></outputEntry>
      </rule>

      <rule>
        <inputEntry><text>0</text></inputEntry>
        <inputEntry><text>0</text></inputEntry>
        <inputEntry><text>&gt; 0</text></inputEntry>
        <outputEntry><text>"MINOR_CONDITIONS"</text></outputEntry>
      </rule>

      <rule>
        <inputEntry><text>0</text></inputEntry>
        <inputEntry><text>0</text></inputEntry>
        <inputEntry><text>0</text></inputEntry>
        <outputEntry><text>"OK"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <!-- ============================================================
       DECISION 3: Coverage Approval
       ============================================================ -->
  <decision id="coverage_status" name="coverage_status">
    <variable name="coverage_status" typeRef="string"/>
    <literalExpression>
      <text>
        if dvr_status = "APPROVED"
          and safety_coverage = "CONFIRMED"
          and requirements_coverage = "CONFIRMED"
        then "COVERAGE_OK"
        else "COVERAGE_FAIL"
      </text>
    </literalExpression>
  </decision>

  <!-- ============================================================
       DECISION 4: TSR Verdict
       ============================================================ -->
  <decision id="tsr_status" name="tsr_status">
    <variable name="tsr_status" typeRef="string"/>
    <decisionTable hitPolicy="UNIQUE">
      <input label="tsr_verdict">
        <inputExpression><text>tsr_verdict</text></inputExpression>
      </input>
      <output name="tsr_status" typeRef="string"/>

      <rule>
        <inputEntry><text>"FAIL"</text></inputEntry>
        <outputEntry><text>"FAIL"</text></outputEntry>
      </rule>

      <rule>
        <inputEntry><text>"PASS_WITH_CONDITIONS"</text></inputEntry>
        <outputEntry><text>"CONDITIONAL"</text></outputEntry>
      </rule>

      <rule>
        <inputEntry><text>"PASS"</text></inputEntry>
        <outputEntry><text>"OK"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <!-- ============================================================
       FINAL DECISION: CAT5 Gate
       ============================================================ -->
  <decision id="cat5_gate" name="cat5_gate">
    <variable name="cat5_gate" typeRef="string"/>
    <literalExpression>
      <text>
        if context_alignment = "MISMATCH"
           or defect_posture in ["FAIL_CRITICAL", "FAIL_MAJOR"]
           or coverage_status = "COVERAGE_FAIL"
           or tsr_status = "FAIL"
        then "FAIL"
        else if defect_posture = "MINOR_CONDITIONS"
             or tsr_status = "CONDITIONAL"
        then "PASS_WITH_CONDITIONS"
        else "PASS"
      </text>
    </literalExpression>
  </decision>

</definitions>
