apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

namespace: zf-mcp

# Reference the base manifests
bases:
  - ../base

# Apply environment-specific patches
patchesStrategicMerge:
  - patch-mcp-values.yaml
  - patch-orch-values.yaml

# Include additional resources (Canary for this env)
resources:
  - canary-mcp.yaml
